VAL_ 256 Radar_Status 0 "OK" 1 "Degraded" 2 "Fault" ;
VAL_ 256 Radar_ObjectType 0 "None" 1 "Vehicle" 2 "Pedestrian" 3 "Unknown" ;
VAL_ 272 Camera_ObjectDetected 0 "No_Object" 1 "Object_Detected" ;
